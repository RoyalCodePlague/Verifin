# Backend (Django) example values only. Do not commit real credentials.
SECRET_KEY=replace-with-a-local-development-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
FRONTEND_URL=http://localhost:8080

# Use local SQLite by leaving DATABASE_URL and DB_* empty.
DATABASE_URL=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Email verification. Console backend prints emails in local dev.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Verifin <noreply@example.com>
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# AI configuration
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
