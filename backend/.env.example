# Backend (Django) example values only. Do not commit real credentials.
SECRET_KEY=replace-with-a-local-development-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
FRONTEND_URL=http://localhost:8080

# Use local SQLite by leaving DATABASE_URL and DB_* empty.
DATABASE_URL=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Email verification.
# Local dev: use console backend to print links in the terminal.
# Gmail SMTP: set EMAIL_BACKEND to smtp backend, use your Gmail address and a Google App Password.
# Never commit real EMAIL_HOST_PASSWORD values.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail-address@gmail.com
EMAIL_HOST_PASSWORD=your-google-app-password
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=15
DEFAULT_FROM_EMAIL=Verifin <your-gmail-address@gmail.com>
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# AI configuration
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
